DATABASE_URL = "sqlite:///./flight_management.db"
# For PostgreSQL: postgresql://user:password@localhost:5432/flight_management

# JWT
SECRET_KEY = "your-secret-key-change-this-in-production"
ALGORITHM = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES = 30

# CORS
CORS_ORIGINS = ["http://localhost:3000", "http://localhost:5173"]

# Google OAuth (fill in on your machine; leave blank in commits)
GOOGLE_CLIENT_ID = "your-google-client-id"
GOOGLE_CLIENT_SECRET = "your-google-client-secret"
GOOGLE_CALLBACK_URL = "http://127.0.0.1:8000/api/auth/google/callback"

# Toggle backend reload/verbose logs
APP_DEBUG = false
